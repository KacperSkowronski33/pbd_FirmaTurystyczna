@page "/my-bookings"
@using BookingApp.Shared.DTOs.RezerwacjaDto
@using System.Net.Http.Headers
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@inject NavigationManager NavManager

<div class="container mt-4">

    @if (pokazBaner)
    {
        <div class="alert alert-success shadow-sm d-flex align-items-center animate-fade-in mb-4" role="alert" style="border-left: 5px solid #198754; transition: opacity 0.5s;">
            <i class="bi bi-check-circle-fill fs-4 me-3 text-success"></i>
            <div>
                <h6 class="alert-heading fw-bold mb-1">Rezerwacja została pomyślnie zarejestrowana!</h6>
                <p class="mb-0 small text-muted">System oczekuje na zaksięgowanie wpłaty z systemu rozliczeniowego. Twój status zaktualizuje się automatycznie.</p>
            </div>
        </div>
    }

    @* NAGŁÓWEK STRONY *@
    <h3 class="fw-bold mb-4"><i class="bi bi-briefcase text-primary"></i> Moje Rezerwacje</h3>

    @if (trwaLadowanie)
    {
        <p><em>Ładowanie Twoich rezerwacji...</em></p>
    }
    else if (rezerwacje == null || !rezerwacje.Any())
    {
        <div class="alert alert-info shadow-sm">
            Nie masz jeszcze żadnych rezerwacji. Czas zaplanować jakieś wakacje!
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var rez in rezerwacje)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body d-flex flex-column justify-content-between">
                            <div>
                                <h5 class="card-title fw-bold">Rezerwacja #@rez.Id</h5>
                                <h6 class="card-subtitle mb-4 text-muted">Złożona: @rez.DataUtworzenia.ToString("dd.MM.yyyy HH:mm")</h6>

                                <p class="mb-2"><i class="bi bi-people me-2 opacity-75"></i>Liczba osób: <strong>@rez.LiczbaOsob</strong></p>
                                <p class="mb-0"><i class="bi bi-wallet2 me-2 opacity-75"></i>Kwota: <strong class="text-success fs-5">@rez.KwotaCalkowita PLN</strong></p>
                            </div>

                            @* ZINTEGROWANA INTEGRACJA STATUSÓW I PRZYCISKU PAYU *@
                            <div class="mt-3 border-top pt-3">
                                @if (rez.StatusPlatnosci == "Completed")
                                {
                                    <span class="badge bg-success p-2 rounded-pill w-100 text-start d-block">
                                        <i class="bi bi-check-circle-fill me-1"></i> Opłacona (System PayU)
                                    </span>
                                }
                                else if (rez.StatusPlatnosci == "Canceled")
                                {
                                    <span class="badge bg-danger p-2 rounded-pill w-100 text-start d-block">
                                        <i class="bi bi-x-circle-fill me-1"></i> Płatność Anulowana
                                    </span>
                                }
                                else
                                {
                                    <div class="d-flex flex-column gap-2">
                                        <span class="badge bg-warning text-dark p-2 rounded-pill text-start">
                                            <i class="bi bi-clock-history me-1"></i> Oczekuje na wpłatę
                                        </span>
                                        <button class="btn btn-success btn-sm rounded-pill px-3 fw-bold shadow-sm mt-1"
                                                @onclick="() => ZaplacZPayU(rez.Id)"
                                                disabled="@processingPayU">
                                            @if (processingPayU && currentRezerwacjaId == rez.Id)
                                            {
                                                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                                <span>Generowanie...</span>
                                            }
                                            else
                                            {
                                                <span><i class="bi bi-credit-card-2-front me-1"></i> Zapłać z PayU</span>
                                            }
                                        </button>
                                    </div>
                                }
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>


@code {
    [SupplyParameterFromQuery(Name = "sukces")] public bool CzySukces { get; set; }

    private bool pokazBaner = false;
    private List<ReadRezerwacjaDto>? rezerwacje;
    private bool trwaLadowanie = true;

    private bool processingPayU = false;
    private int currentRezerwacjaId = 0;
    private string komunikatBleduPayU = "";

    protected override async Task OnParametersSetAsync()
    {
        if (CzySukces && !pokazBaner)
        {
            pokazBaner = true;
            _ = UruchomOdliczanieBaneru();
        }
    }

    private async Task UruchomOdliczanieBaneru()
    {
        await Task.Delay(10000);

        pokazBaner = false;
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        var token = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "authToken");

        if (string.IsNullOrEmpty(token))
        {
            NavManager.NavigateTo("/login");
            return;
        }

        var request = new HttpRequestMessage(HttpMethod.Get, "api/Rezerwacje/moje");
        request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);

        try
        {
            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                rezerwacje = await response.Content.ReadFromJsonAsync<List<ReadRezerwacjaDto>>();
            }
            else
            {
                Console.WriteLine($"Błąd pobierania: API zwróciło status {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Błąd połączenia: " + ex.Message);
        }
        finally
        {
            trwaLadowanie = false;
        }
    }

    private async Task ZaplacZPayU(int rezerwacjaId)
    {
        processingPayU = true;
        currentRezerwacjaId = rezerwacjaId;
        komunikatBleduPayU = "";

        try
        {
            var token = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "authToken");

            var request = new HttpRequestMessage(HttpMethod.Post, $"api/payu/order/{rezerwacjaId}");
            if (!string.IsNullOrEmpty(token))
            {
                request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
            }

            var response = await Http.SendAsync(request);

            BookingApp.Shared.ApiResponse.ApiResponse<string>? result = null;
            try
            {
                result = await response.Content.ReadFromJsonAsync<BookingApp.Shared.ApiResponse.ApiResponse<string>>();
            }
            catch { /* ignoruj błąd parsowania */ }

            if (response.IsSuccessStatusCode && result != null && result.Sukces && !string.IsNullOrEmpty(result.Dane))
            {
                NavManager.NavigateTo(result.Dane, forceLoad: true);
            }
            else
            {
                komunikatBleduPayU = result?.Wiadomosc ?? $"Błąd serwera (HTTP {response.StatusCode}).";
            }
        }
        catch (Exception ex)
        {
            komunikatBleduPayU = $"Błąd krytyczny połączenia: {ex.Message}";
        }
        finally
        {
            processingPayU = false;
        }

        if (!string.IsNullOrEmpty(komunikatBleduPayU))
        {
            await JSRuntime.InvokeVoidAsync("alert", komunikatBleduPayU);
        }
    }
}