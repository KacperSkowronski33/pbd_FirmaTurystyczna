@page "/favorites"
@using BookingApp.Shared.ApiResponse
@using BookingApp.Shared.DTOs.OfertaDto
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize] 
@inject HttpClient Http
@inject NavigationManager NavManager

<div class="container mt-4 mb-5" style="max-width: 1024px;">
    <div class="d-flex align-items-center mb-2">
        <h3 class="fw-bold text-danger mb-0"><i class="bi bi-heart-fill"></i> Twoje Zapisane Wakacje</h3>
    </div>
    <p class="text-muted small">Wszystkie polubione oferty zapisane na Twoim profilu klienta.</p>
    <hr />

    @if (wczytywanie)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-danger" role="status"></div>
            <p class="text-muted small mt-2">Pobieranie listy ulubionych ofert...</p>
        </div>
    }
    else if (ulubioneOferty == null || !ulubioneOferty.Any())
    {
        <div class="text-center py-5 bg-white rounded shadow-sm border text-muted">
            <i class="bi bi-heartbreak text-light-emphasis fs-1 d-block mb-3"></i>
            <h5 class="fw-bold text-dark">Twoja lista ulubionych jest pusta</h5>
            <p class="small px-3">Przeglądaj najnowsze turnusy na stronie głównej i klikaj ikony serc, aby zapisać je tutaj.</p>
            <a href="" class="btn btn-primary btn-sm rounded-pill px-4 fw-bold mt-2">Przeglądaj oferty</a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var offer in ulubioneOferty)
            {
                var minimalnaCena = offer.TerminyCeny != null && offer.TerminyCeny.Any()
                                    ? offer.TerminyCeny.Min(t => t.CenaPodstawowa)
                                    : 0;
                var zdjecieUrl = offer.Hotel?.ZdjeciaHotelu?.FirstOrDefault()?.UrlZdjecia ?? "images/logo.jpg";
                var nazwaHotelu = offer.Hotel?.NazwaHotelu ?? "Nieznany hotel";
                var lokalizacja = offer.Hotel?.Miejscowosc?.Nazwa ?? "Brak danych";
                var gwiazdki = offer.Hotel?.LiczbaGwiazdek ?? 0;

                <div class="col">
                    <div class="card h-100 shadow-sm border-0 rounded overflow-hidden position-relative offer-card-fav">
                        
                        @* ODCIĄGNIĘCIE Z ULUBIONYCH *@
                        <button class="btn btn-light rounded-circle shadow-sm position-absolute border-0 p-2 d-flex align-items-center justify-content-center" 
                                style="top: 12px; right: 12px; z-index: 10; width: 36px; height: 36px;"
                                @onclick="() => UsunZFavorites(offer.Id)">
                            <i class="bi bi-heart-fill text-danger fs-5"></i>
                        </button>

                        <div style="background-image: url('@zdjecieUrl'); height: 180px; background-size: cover; background-position: center;"></div>
                        
                        <div class="card-body d-flex flex-column p-3">
                            <h5 class="fw-bold text-dark mb-1 text-truncate">@nazwaHotelu</h5>
                            <p class="text-muted small mb-2"><i class="bi bi-geo-alt-fill text-danger"></i> @lokalizacja</p>
                            <span class="badge bg-secondary align-self-start mb-3">@offer.TypWyzywienia?.NazwaWyzywienia</span>
                            
                            <div class="d-flex justify-content-between align-items-center mt-auto border-top pt-2">
                                <div>
                                    <span class="text-muted d-block" style="font-size: 11px; line-height: 1;">od próg</span>
                                    <span class="fw-bold text-success fs-5">@minimalnaCena.ToString("C0")</span>
                                </div>
                                <button class="btn btn-outline-primary btn-sm rounded-pill px-3 fw-bold" 
                                        @onclick='() => NavManager.NavigateTo($"offer-details/{offer.Id}")'>
                                    Szczegóły
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<ReadOfertaDto>? ulubioneOferty;
    private bool wczytywanie = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var res = await Http.GetFromJsonAsync<ApiResponse<List<ReadOfertaDto>>>("api/ulubione");
            if (res != null && res.Sukces)
            {
                ulubioneOferty = res.Dane;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Błąd pobierania ulubionych: {ex.Message}");
        }
        wczytywanie = false;
    }

    private async Task UsunZFavorites(int offerId)
    {
        var res = await Http.DeleteAsync($"api/ulubione/{offerId}");
        if (res.IsSuccessStatusCode)
        {
            ulubioneOferty?.RemoveAll(o => o.Id == offerId); 
        }
    }
}

<style>
    .offer-card-fav {
        transition: 0.2s;
    }
    .offer-card-fav:hover {
        transform: translateY(-3px);
    }
</style>