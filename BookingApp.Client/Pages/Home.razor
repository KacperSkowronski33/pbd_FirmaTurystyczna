@page "/"

@* Sekcja Header (Niebieskie tło pod wyszukiwarką) *@
<div class="hero-section">
    <div class="container text-start">
        <h1>Znajdź swój następny pobyt</h1>
        <p>Szukaj ofert hoteli, domów i innych obiektów...</p>
    </div>
</div>

@* Żółta Wyszukiwarka *@
<div class="search-container shadow-lg">
    <div class="search-input-group flex-grow-1">
        <span class="me-2">🛏️</span>
        <input type="text" id="miejsce" placeholder="Dokąd się wybierasz?" class="w-100" />
    </div>
    <div class="search-input-group">
        <span class="me-2">📅</span>
        <input type="date" id="data_od" title="Data zameldowania" />
        <span class="mx-2">-</span>
        <input type="date" id="data_do" title="Data wymeldowania" />
    </div>
    <div class="search-input-group">
        <span class="me-2">👤</span>
        <input type="text" id="osoby" placeholder="2 dorosłych · 1 pokój" />
    </div>
    <button class="search-btn">Szukaj</button>
</div>

@* Sekcja Wyników *@
<div class="listings-section container">
    <h2 class="fw-bold mb-4">Najnowsze oferty</h2>

    <div class="grid-container">
        @if (Offers == null)
        {
            @* Szkielet ładowania (Placeholdery) *@
            @for (int i = 0; i < 4; i++)
            {
                <div class="card-placeholder animate-pulse">
                    <div class="placeholder-photo">Pobieranie zdjęcia...</div>
                    <div class="placeholder-content">
                        <div class="placeholder-box fw-bold text-muted">[ Nazwa obiektu ]</div>
                        <div class="placeholder-box small">[ Lokalizacja ]</div>
                        <div class="placeholder-footer mt-auto">
                            <div class="placeholder-box flex-fill">[ Ocena ]</div>
                            <div class="placeholder-box flex-fill fw-bold">[ Cena ]</div>
                        </div>
                    </div>
                </div>
            }
        }
        else if (!Offers.Any())
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-info-circle fs-1 text-muted"></i>
                <p class="mt-3 text-muted">Baza danych jest pusta. Brak ofert do wyświetlenia.</p>
            </div>
        }
        else
        {
            @foreach (var offer in Offers)
            {
                <div class="offer-card shadow-sm">
                    <div class="offer-photo" style="background-image: url('@offer.ImageUrl')">
                        @if (offer.Discount)
                        {
                            <span class="badge bg-danger m-2">Okazja</span>
                        }
                    </div>
                    <div class="offer-content">
                        <h5 class="fw-bold mb-1">@offer.Title</h5>
                        <p class="text-muted small mb-3"><i class="bi bi-geo-alt"></i> @offer.Location</p>
                        <div class="d-flex justify-content-between align-items-center mt-auto">
                            <div class="rating bg-primary text-white p-1 px-2 rounded small">@offer.Rating</div>
                            <div class="text-end">
                                <span class="small text-muted d-block">od</span>
                                <span class="fw-bold fs-5 text-dark">@offer.Price zł</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    // Model danych
    public class OfferViewModel
    {
        public string Title { get; set; } = "";
        public string Location { get; set; } = "";
        public decimal Price { get; set; }
        public string ImageUrl { get; set; } = "";
        public string Rating { get; set; } = "8.5";
        public bool Discount { get; set; } = false;
    }

    private List<OfferViewModel>? Offers;

    protected override async Task OnInitializedAsync()
    {
        // Symulacja pobierania z bazy
        await Task.Delay(1000);

        // Zostawiam pustą listę zgodnie z prośbą o puste miejsce z bazy
        Offers = new List<OfferViewModel>();

        // Aby przetestować wygląd z danymi, odkomentuj poniższe:
        /*
        Offers = new List<OfferViewModel> {
            new OfferViewModel { Title = "Grand Hotel Lux", Location = "Gdańsk", Price = 450, ImageUrl = "https://images.unsplash.com/photo-1566073771259-6a8506099945?w=400" }
        };
        */
    }
}

<style>
    :root {
        --primary-blue: #003580;
        --secondary-blue: #0071c2;
        --accent-yellow: #febb02;
    }

    .hero-section {
        background-color: var(--primary-blue);
        color: white;
        padding: 60px 0 100px 0;
    }

        .hero-section h1 {
            font-size: 3rem;
            font-weight: 700;
        }

    .search-container {
        background-color: var(--accent-yellow);
        padding: 4px;
        border-radius: 8px;
        display: flex;
        gap: 4px;
        max-width: 1024px;
        margin: -40px auto 0 auto;
        position: relative;
    }

    .search-input-group {
        display: flex;
        background: white;
        align-items: center;
        padding: 8px 15px;
        border-radius: 4px;
    }

        .search-input-group input {
            border: none;
            outline: none;
            font-size: 14px;
        }

    .search-btn {
        background-color: var(--secondary-blue);
        color: white;
        border: none;
        padding: 0 30px;
        font-size: 1.2rem;
        font-weight: 700;
        border-radius: 4px;
        cursor: pointer;
    }

    .listings-section {
        margin-top: 60px;
        padding-bottom: 60px;
    }

    .grid-container {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 24px;
    }

    /* Style dla ofert / placeholderów */
    .card-placeholder, .offer-card {
        border-radius: 8px;
        background-color: #fff;
        display: flex;
        flex-direction: column;
        min-height: 350px;
        border: 1px solid #ddd;
        overflow: hidden;
    }

    .placeholder-photo, .offer-photo {
        height: 200px;
        background-color: #f0f0f0;
        background-size: cover;
        background-position: center;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #999;
    }

    .placeholder-content, .offer-content {
        padding: 15px;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .placeholder-box {
        border: 1px dashed #ccc;
        padding: 5px;
        margin-bottom: 8px;
        text-align: center;
        border-radius: 4px;
    }

    .animate-pulse {
        animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }

    @@keyframes pulse {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: .5;
        }
    }

    .offer-card:hover {
        transform: translateY(-5px);
        transition: 0.3s;
    }
</style>