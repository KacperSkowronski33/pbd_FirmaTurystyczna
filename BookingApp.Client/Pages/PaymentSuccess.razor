@page "/payment/success"
@inject NavigationManager NavManager

<div class="container mt-5 text-center" style="max-width: 600px;">
    <div class="card shadow border-0 p-5 rounded-3 bg-white">
        <div class="mb-4">
            <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
        </div>
        <h2 class="fw-bold text-dark mb-3">Płatność zakończona sukcesem!</h2>
        <p class="text-muted mb-4">
            Twoja wpłata została pomyślnie zarejestrowana. Status rezerwacji w bazie danych zostanie automatycznie zaktualizowany w ciągu kilkunastu sekund.
        </p>
        <div class="d-grid gap-2">
            <button class="btn btn-primary rounded-pill fw-bold py-2" @onclick='() => NavManager.NavigateTo("my-bookings")'>
                <i class="bi bi-briefcase me-2"></i> Przejdź do Moich Rezerwacji
            </button>
            <button class="btn btn-outline-secondary rounded-pill fw-bold py-2" @onclick='() => NavManager.NavigateTo("")'>
                <i class="bi bi-house me-2"></i> Powrót do Strony Głównej
            </button>
        </div>
    </div>
</div>