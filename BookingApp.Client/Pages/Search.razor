@page "/search"
@using BookingApp.Shared.ApiResponse
@using BookingApp.Shared.DTOs.OfertaDto
@using BookingApp.Shared.Models
@inject NavigationManager NavManager
@inject HttpClient Http

<div class="container mt-4">
    <div class="row">
        @* SIDEBAR Z FILTRAMI *@
        <aside class="col-lg-3">
            <div class="filter-card p-3 bg-white shadow-sm rounded border">
                <h6 class="fw-bold mb-3 border-bottom pb-2">Filtruj wyniki</h6>

                @if (!string.IsNullOrEmpty(Dokad))
                {
                    <div class="mb-3 alert alert-secondary py-1 px-2 small">
                        Cel podróży: <strong>@Dokad</strong>
                    </div>
                }

                <div class="mb-4">
                    <label class="form-label small fw-bold">Budżet (do @PriceLimit zł)</label>
                    <input type="range" class="form-range" min="500" max="10000" step="100"
                           @bind="PriceLimit" @bind:event="oninput" @bind:after="PerformSearch">
                </div>

                <div class="mb-4">
                    <label class="form-label small fw-bold">Standard</label>
                    <div class="form-check small">
                        <input class="form-check-input" type="checkbox" @bind="pokaz3Gwiazdki" @bind:after="PerformSearch"> 3 gwiazdki
                    </div>
                    <div class="form-check small">
                        <input class="form-check-input" type="checkbox" @bind="pokaz4Gwiazdki" @bind:after="PerformSearch"> 4 gwiazdki
                    </div>
                    <div class="form-check small">
                        <input class="form-check-input" type="checkbox" @bind="pokaz5Gwiazdki" @bind:after="PerformSearch"> 5 gwiazdek
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label small fw-bold">Wyżywienie</label>
                    <select class="form-select form-select-sm" @bind="selectedWyzywienieId" @bind:after="PerformSearch">
                        <option value="">Wszystkie</option>
                        @if (slownikWyzywienia != null)
                        {
                            @foreach (var w in slownikWyzywienia)
                            {
                                <option value="@w.Id">@w.NazwaWyzywienia</option>
                            }
                        }
                    </select>
                </div>
            </div>
        </aside>

        @* LISTA WYNIKÓW *@
        <main class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0">Znaleziono: @(FoundOffers?.Count ?? 0) ofert</h5>
                <select class="form-select form-select-sm w-auto">
                    <option>Najniższa cena</option>
                    <option>Najlepsze oceny</option>
                </select>
            </div>

            @if (FoundOffers == null)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2 text-muted">Szukamy najlepszych ofert...</p>
                </div>
            }
            else if (!FoundOffers.Any())
            {
                <div class="alert alert-info shadow-sm">
                    <i class="bi bi-info-circle me-2"></i>
                    Nie znaleźliśmy ofert spełniających Twoje kryteria. Spróbuj zmienić filtry.
                </div>
            }
            else
            {
                @foreach (var offer in FoundOffers)
                {
                    var zdjecieUrl = offer.Hotel?.ZdjeciaHotelu?.FirstOrDefault()?.UrlZdjecia ?? "images/logo.jpg";
                    var nazwaHotelu = offer.Hotel?.NazwaHotelu ?? "Nieznana oferta";
                    var gwiazdki = offer.Hotel?.LiczbaGwiazdek ?? 0;
                    
                    var minimalnaCena = offer.TerminyCeny != null && offer.TerminyCeny.Any()
                                        ? offer.TerminyCeny.Min(t => t.CenaPodstawowa)
                                        : 0;

                    var miejscowosc = offer.Hotel?.Miejscowosc?.Nazwa ?? "Nieznana Miejscowosc";
                    var wyzywienie = offer.TypWyzywienia?.NazwaWyzywienia ?? "Brak danych";

                    <div class="card mb-3 horizontal-offer shadow-sm border-0">
                        <div class="row g-0">
                            <div class="col-md-4">
                                <div class="h-100 min-vh-20 bg-light position-relative" style="background: url('@zdjecieUrl') center/cover; min-height: 200px;">
                                </div>
                            </div>
                            <div class="col-md-8">
                                <div class="card-body d-flex flex-column h-100">
                                    <div class="d-flex justify-content-between">
                                        <h5 class="card-title fw-bold">@nazwaHotelu</h5>
                                        <div class="text-primary fw-bold">
                                            @gwiazdki <i class="bi bi-star-fill text-warning"></i>
                                        </div>
                                    </div>
                                    
                                    <div class="mt-auto d-flex justify-content-between align-items-end">
                                        <div class="tags">
                                            <span class="badge border text-muted fw-normal me-1"><i class="bi bi-geo-alt"></i> @miejscowosc</span>
                                            <span class="badge border text-muted fw-normal me-1"><i class="bi bi-cup-hot"></i> @wyzywienie</span>
                                        </div>
                                        <div class="text-end">
                                            <div class="text-muted small">Cena za osobę od</div>
                                            <div class="fs-4 fw-bold text-primary">@minimalnaCena.ToString("C0")</div>
                                            @* Przekazujemy realną liczbę osób dalej do karty szczegółów *@
                                            <button class="btn btn-primary btn-sm px-4 rounded-pill mt-1"
                                                    @onclick='() => NavManager.NavigateTo($"offer-details/{offer.Id}?osoby={LiczbaOsob}")'>
                                                Wybierz
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </main>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "skad")] public string? Skad { get; set; }
    [SupplyParameterFromQuery(Name = "dokad")] public string? Dokad { get; set; }
    [SupplyParameterFromQuery(Name = "dataOd")] public DateTime? DataOd { get; set; }
    [SupplyParameterFromQuery(Name = "dataDo")] public DateTime? DataDo { get; set; }
    [SupplyParameterFromQuery(Name = "liczbaOsob")] public int LiczbaOsob { get; set; } = 2;

    private int PriceLimit = 5000;
    private List<ReadOfertaDto>? FoundOffers;
    
    private bool pokaz3Gwiazdki;
    private bool pokaz4Gwiazdki;
    private bool pokaz5Gwiazdki;
    private string? selectedWyzywienieId;
    private List<TypWyzywienia>? slownikWyzywienia;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<ApiResponse<List<TypWyzywienia>>>("api/Lookups/typy-wyzywienia");
            if (response != null && response.Sukces)
            {
                slownikWyzywienia = response.Dane;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Błąd pobierania wyżywień: {ex.Message}");
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        await PerformSearch();
    }

    private async Task PerformSearch()
    {
        var wybraneGwiazdki = new List<string>();
        if (pokaz3Gwiazdki) wybraneGwiazdki.Add("3");
        if (pokaz4Gwiazdki) wybraneGwiazdki.Add("4");
        if (pokaz5Gwiazdki) wybraneGwiazdki.Add("5");
        string gwiazdkiParam = string.Join(",", wybraneGwiazdki);

        var url = $"api/oferty?cel={Uri.EscapeDataString(Dokad ?? "")}" +
                  $"&maxCena={PriceLimit}" +
                  $"&gwiazdki={gwiazdkiParam}";

        if (!string.IsNullOrEmpty(selectedWyzywienieId))
        {
            url += $"&typWyzywieniaId={selectedWyzywienieId}";
        }

        var response = await Http.GetFromJsonAsync<ApiResponse<List<ReadOfertaDto>>>(url);
        if (response != null && response.Sukces)
        {
            FoundOffers = response.Dane;
        }
    }
}

<style>
    .horizontal-offer {
        min-height: 200px;
        transition: 0.2s;
        overflow: hidden;
    }

        .horizontal-offer:hover {
            transform: scale(1.005);
        }

    .min-vh-20 {
        min-height: 200px;
    }

    .filter-card {
        position: sticky;
        top: 90px;
    }
</style>