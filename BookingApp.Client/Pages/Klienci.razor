@page "/admin/klienci"
@using BookingApp.Shared.ApiResponse
@using BookingApp.Shared.DTOs.KlientDto
@inject HttpClient Http

<h3>Klienci</h3>

@if (klienci == null)
{
    <p>Ładowanie...</p>
}
else if (!klienci.Any())
{
    <p>Brak klientów</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>Email</th>
                <th>Imię</th>
                <th>Nazwisko</th>
                <th>Akcje</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var k in klienci)
            {
                <tr>
                    <td>@k.Id</td>
                    <td>@k.Email</td>
                    <td>@k.Imie</td>
                    <td>@k.Nazwisko</td>
                    <td>
                        <button class="btn btn-danger btn-sm" @onclick="() => UsunKlienta(k.Id)">Usuń</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<ReadKlientDto>? klienci;

    protected override async Task OnInitializedAsync()
    {
        var response = await Http.GetFromJsonAsync<ApiResponse<List<ReadKlientDto>>>("api/klienci");
        if (response != null && response.Sukces)
        {
            klienci = response.Dane;
        }
    }

    private async Task UsunKlienta(int id)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/klienci/{id}");
            if (response.IsSuccessStatusCode && klienci != null)
            {
                klienci.RemoveAll(k => k.Id == id);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Błąd usuwania: {ex.Message}");
        }
    }
}