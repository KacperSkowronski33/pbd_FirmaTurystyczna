@page "/admin/klienci"
@inject HttpClient Http

<h3>Klienci</h3>

@if (klienci == null)
{
    <p>Ładowanie...</p>
}
else if (!klienci.Any())
{
    <p>Brak klientów</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Email</th>
                <th>Imię</th>
                <th>Nazwisko</th>
                <th>Akcje</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var k in klienci)
            {
                <tr>
                    <td>@k.Id</td>
                    <td>@k.Email</td>
                    <td>@k.Imie</td>
                    <td>@k.Nazwisko</td>
                    <td>
                        <button class="btn btn-danger btn-sm" @onclick="() => UsunKlienta(k.Id)">Usuń</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<KlientDto> klienci;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<ApiResponseWrapper>("api/klienci");

            if (response != null && response.Sukces)
            {
                klienci = response.Dane;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Błąd pobierania: {ex.Message}");
        }
    }

    private async Task UsunKlienta(int id)
    {
        await Http.DeleteAsync($"api/klienci/{id}");
        if (klienci != null)
        {
            klienci.RemoveAll(k => k.Id == id);
        }
    }
    public class ApiResponseWrapper
    {
        public bool Sukces { get; set; }
        public string Wiadomosc { get; set; }
        public List<KlientDto> Dane { get; set; }
    }

    public class KlientDto
    {
        public int Id { get; set; }
        public string Email { get; set; }
        public string Imie { get; set; }
        public string Nazwisko { get; set; }
    }
}