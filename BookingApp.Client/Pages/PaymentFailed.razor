@page "/payment/failure"
@inject NavigationManager NavManager

<div class="container mt-5 text-center" style="max-width: 600px;">
    <div class="card shadow border-0 p-5 rounded-3 bg-white">
        <div class="mb-4">
            <i class="bi bi-x-circle-fill text-danger" style="font-size: 5rem;"></i>
        </div>
        <h2 class="fw-bold text-dark mb-3">Płatność nie powiodła się</h2>
        <p class="text-muted mb-4">
            Transakcja została anulowana, odrzucona przez bank lub przekroczono limit czasu na jej realizację. Twoja rezerwacja nadal jest ważna – możesz spróbować opłacić ją ponownie.
        </p>
        <div class="d-grid gap-2">
            <button class="btn btn-danger rounded-pill fw-bold py-2" @onclick='() => NavManager.NavigateTo("my-bookings")'>
                <i class="bi bi-arrow-clockwise me-2"></i> Spróbuj ponownie
            </button>
            <button class="btn btn-outline-secondary rounded-pill fw-bold py-2" @onclick='() => NavManager.NavigateTo("")'>
                <i class="bi bi-house me-2"></i> Powrót do Strony Głównej
            </button>
        </div>
    </div>
</div>