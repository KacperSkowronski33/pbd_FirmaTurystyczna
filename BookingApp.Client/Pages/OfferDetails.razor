@page "/offer-details/{Id:int}"
@using BookingApp.Shared.ApiResponse
@using BookingApp.Shared.DTOs.OfertaDto
@using BookingApp.Shared.Models
@inject NavigationManager NavManager
@inject HttpClient Http

<div class="container mt-4">
    @if (Offer == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Pobieranie szczegółów oferty...</p>
        </div>
    }
    else
    {
        var nazwaHotelu = Offer.Hotel?.NazwaHotelu ?? "Nieznany obiekt";
        var lokalizacja = $"{Offer.Hotel?.Miejscowosc?.Nazwa}, {Offer.Hotel?.Miejscowosc?.KrajId}";
        var gwiazdki = Offer.Hotel?.LiczbaGwiazdek ?? 0;
        
        var wszystkieZdjecia = Offer.Hotel?.ZdjeciaHotelu?.Select(z => z.UrlZdjecia).ToList() ?? new List<string>();
        var glowneZdjecie = wszystkieZdjecia.FirstOrDefault() ?? "images/logo.jpg";
        var galeria = wszystkieZdjecia.Skip(1).ToList();

        @* Nagłówek *@
        <div class="row mb-4">
            <div class="col-12">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb small">
                        <li class="breadcrumb-item"><a href="/">Strona główna</a></li>
                        <li class="breadcrumb-item"><a href="/search">Wyniki wyszukiwania</a></li>
                        <li class="breadcrumb-item active">@nazwaHotelu</li>
                    </ol>
                </nav>
                <div class="d-flex justify-content-between align-items-end mb-3">
                    <div>
                        <h2 class="fw-bold mb-1">@nazwaHotelu</h2>
                        <p class="text-muted mb-0"><i class="bi bi-geo-alt-fill text-primary"></i> @lokalizacja</p>
                    </div>
                    <div class="text-end">
                        <span class="badge bg-primary fs-5">
                            @gwiazdki <i class="bi bi-star-fill"></i>
                        </span>
                        <p class="small text-muted mb-0">(Kategoria hotelu)</p>
                    </div>
                </div>
            </div>

            @* Galeria *@
            <div class="col-lg-8">
                <div class="main-photo mb-2" style="background-image: url('@glowneZdjecie'); height: 400px; background-size: cover; border-radius: 8px;"></div>
                <div class="row g-2">
                    @foreach (var img in galeria.Take(4))
                    {
                        <div class="col-3">
                            <div class="sub-photo" style="background-image: url('@img'); height: 90px; background-size: cover; border-radius: 4px;"></div>
                        </div>
                    }
                </div>
            </div>

            @* PANEL REZERWACJI *@
            <div class="col-lg-4">
                <div class="booking-widget p-4 shadow-sm border rounded bg-white">
                    <h5 class="fw-bold mb-3">Twoja rezerwacja</h5>
                    
                    @* wybór liczby osób *@
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Liczba uczestników:</label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text">👤</span>
                            <input type="number" class="form-control" min="1" max="10" @bind="Osoby" />
                        </div>
                    </div>

                    @* wybór terminu prosto z bazy *@
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Wybierz termin pobytu:</label>
                        @if (Offer.TerminyCeny != null && Offer.TerminyCeny.Any())
                        {
                            <select class="form-select form-select-sm" @bind="wybraneTerminCenaId">
                                @foreach (var t in Offer.TerminyCeny.OrderBy(x => x.DataOd))
                                {
                                    <option value="@t.Id">
                                        @t.DataOd.ToString("dd.MM.yyyy") - @t.DataDo.ToString("dd.MM.yyyy") (@t.CenaPodstawowa.ToString("C0") / os.)
                                    </option>
                                }
                            </select>
                        }
                        else
                        {
                            <div class="text-danger small py-1"><i class="bi bi-exclamation-circle"></i> Brak dostępnych terminów.</div>
                        }
                    </div>

                    @* podsumowanie kosztów *@
                    @if (wybranyTermin != null)
                    {
                        <div class="mb-4 p-3 bg-light rounded border">
                            <div class="d-flex justify-content-between align-items-center mb-1 small text-muted">
                                <span>Cena za osobę:</span>
                                <span class="fw-bold text-dark">@wybranyTermin.CenaPodstawowa.ToString("C0")</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mb-1 small text-muted">
                                <span>Liczba osób:</span>
                                <span class="fw-bold text-dark">@Osoby</span>
                            </div>
                            <hr class="my-2" />
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold fs-5">Suma:</span>
                                <span class="fw-bold fs-4 text-primary">@((wybranyTermin.CenaPodstawowa * Osoby).ToString("C0"))</span>
                            </div>
                            <p class="text-muted text-center small mt-2 mb-0" style="font-size: 0.75rem;">
                                Kalkulacja pobrana bezpośrednio z bazy danych.
                            </p>
                        </div>
                    }

                    @* Przycisk przesyła do checkoutu ID konkretnego TERMINU *@
                    <button class="btn btn-primary w-100 py-3 fw-bold rounded-pill shadow"
                            @onclick="HandleBooking"
                            disabled="@(wybraneTerminCenaId == null || Osoby < 1)">
                        REZERWUJ TERAZ
                    </button>
                    
                    @if (!string.IsNullOrEmpty(komunikat))
                    {
                        <div class="alert alert-warning mt-3 small text-center p-2">@komunikat</div>
                    }
                </div>
            </div>
        </div>

        @* SEKCJA ZAKŁADEK  *@
        <div class="row mt-4">
            <div class="col-lg-8">
                <ul class="nav nav-tabs custom-tabs mb-4">
                    <li class="nav-item">
                        <button class="nav-link @(ActiveTab == "hotel" ? "active" : "")" @onclick='() => ActiveTab = "hotel"'>O ofercie</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link @(ActiveTab == "rooms" ? "active" : "")" @onclick='() => ActiveTab = "rooms"'>Pokoje</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link @(ActiveTab == "reviews" ? "active" : "")" @onclick='() => ActiveTab = "reviews"'>Informacje dodatkowe</button>
                    </li>
                </ul>

                <div class="tab-content pb-5">
                    @if (ActiveTab == "hotel")
                    {
                        <div class="animate-fade-in">
                            <h5 class="fw-bold">Szczegóły oferty</h5>
                            <p>
                                <strong>Typ wyżywienia:</strong>
                                @(Offer.TypWyzywienia?.NazwaWyzywienia ?? "Brak szczegółowych danych")
                            </p>

                            @if (Offer.Hotel != null)
                            {
                                <h5 class="fw-bold mt-4">Informacje o obiekcie</h5>
                                <p><i class="bi bi-building me-2"></i>Nazwa: @Offer.Hotel.NazwaHotelu</p>
                                <p><i class="bi bi-star me-2"></i>Standard: @Offer.Hotel.LiczbaGwiazdek gwiazdek</p>
                            }
                        </div>
                    }
                    else if (ActiveTab == "rooms")
                    {
                        <div class="animate-fade-in">
                            <h5 class="fw-bold mb-3">Struktura pokoi w hotelu</h5>
                            <p class="text-muted small">
                                Obiekt posiada dedykowane strefy mieszkalne dopasowane do wybranego standardu.
                                Szczegółowy podział na pokoje jedno- i dwuosobowe oraz dobór łóżek następuje automatycznie w kroku uzupełniania danych podróżnych.
                            </p>
                            <span class="badge border text-muted p-2"><i class="bi bi-info-circle me-1"></i> Oferta powiązana bezpośrednio z bazą rodzajów pokojów obiektu.</span>
                        </div>
                    }
                    else if (ActiveTab == "reviews")
                    {
                        <div class="animate-fade-in">
                            <h5 class="fw-bold mb-3">Ważne informacje dla podróżnych</h5>
                            <div class="p-3 bg-light rounded border small text-muted">
                                <p class="mb-2">⏱️ <strong>Doba hotelowa:</strong> Zameldowanie od godziny 14:00, wymeldowanie do godziny 10:00 rano.</p>
                                <p class="mb-2">🧳 <strong>Bagaż:</strong> Możliwość bezpłatnego pozostawienia bagażu w recepcji hotelu przed zameldowaniem.</p>
                                <p class="mb-0">💳 <strong>Opłata klimatyczna:</strong> Może być wymagana dodatkowa opłata na miejscu (zależna od przepisów lokalnych danej miejscowości).</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }
    [SupplyParameterFromQuery(Name = "osoby")] public int Osoby { get; set; } = 2;

    private ReadOfertaDto? Offer;
    private string komunikat = "";
    private string ActiveTab = "hotel";
    
    private int? wybraneTerminCenaId;
    private TerminCena? wybranyTermin => Offer?.TerminyCeny?.FirstOrDefault(t => t.Id == wybraneTerminCenaId);

    protected override async Task OnInitializedAsync()
    {
        var response = await Http.GetFromJsonAsync<ApiResponse<ReadOfertaDto>>($"api/oferty/{Id}");
        if (response != null && response.Sukces)
        {
            Offer = response.Dane;
            
            var domyslnyTermin = Offer?.TerminyCeny?.OrderBy(t => t.CenaPodstawowa).FirstOrDefault();
            if (domyslnyTermin != null)
            {
                wybraneTerminCenaId = domyslnyTermin.Id;
            }
        }
        else
        {
            komunikat = "Nie znaleziono takiej oferty.";
        }
    }

    private void HandleBooking()
    {
        if (wybraneTerminCenaId.HasValue)
        {
            NavManager.NavigateTo($"/checkout/{wybraneTerminCenaId.Value}?offerId={Offer.Id}&liczbaOsob={Osoby}");
        }
    }
}

<style>
    .main-photo {
        height: 400px;
        background-size: cover;
        background-position: center;
        border-radius: 12px;
    }

    .sub-photo {
        height: 100px;
        background-size: cover;
        background-position: center;
        border-radius: 8px;
        background-color: #f0f0f0;
    }

    .booking-widget {
        position: sticky;
        top: 100px;
        z-index: 10;
    }

    .custom-tabs .nav-link {
        border: none;
        color: #666;
        font-weight: 500;
        border-bottom: 3px solid transparent;
    }

        .custom-tabs .nav-link.active {
            color: #003580;
            border-bottom: 3px solid #febb02;
            background: none;
        }

    .animate-fade-in {
        animation: fadeIn 0.3s;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }
</style>