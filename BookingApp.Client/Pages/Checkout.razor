@page "/checkout/{TerminCenaId:int}"
@using BookingApp.Shared.DTOs.RezerwacjaDto
@using BookingApp.Shared.DTOs.OfertaDto
@using BookingApp.Shared.DTOs.KlientDto
@using BookingApp.Shared.Models
@using BookingApp.Shared.ApiResponse
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime

<div class="container mt-4 pb-5">
    @* STEPPER *@
    <div class="row justify-content-center mb-5">
        <div class="col-md-10">
            <div class="stepper-wrapper d-flex justify-content-between position-relative">
                <div class="stepper-line"></div>
                <div class="stepper-item @(CurrentStep >= 1 ? "active" : "")">
                    <div class="step-counter">1</div>
                    <div class="step-name">Dane podróżnych</div>
                </div>
                <div class="stepper-item @(CurrentStep >= 2 ? "active" : "")">
                    <div class="step-counter">2</div>
                    <div class="step-name">Dodatki</div>
                </div>
                <div class="stepper-item @(CurrentStep >= 3 ? "active" : "")">
                    <div class="step-counter">3</div>
                    <div class="step-name">Podsumowanie</div>
                </div>
            </div>
        </div>
    </div>

    @* KOMUNIKAT BŁĘDU *@
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mb-4 text-center shadow-sm">@errorMessage</div>
    }

    <div class="row">
        @* LEWA KOLUMNA: FORMULARZE *@
        <div class="col-lg-8">
            @if (CurrentStep == 1)
            {
                <div class="card shadow-sm border-0 p-4 animate-slide">
                    <h4 class="fw-bold mb-4">Uczestnicy wyjazdu</h4>
                    
                    @for (int i = 0; i < Podrozni.Count; i++)
                    {
                        var index = i;
                        <div class="mb-4 p-3 border rounded bg-white">
                            <h6 class="fw-bold text-primary mb-3">Podróżny #@(index + 1) @(index == 0 ? "(Główny rezerwujący)" : "")</h6>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label small">Imię</label>
                                    <input type="text" class="form-control form-control-sm" placeholder="Jan" @bind="Podrozni[index].Imie">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small">Nazwisko</label>
                                    <input type="text" class="form-control form-control-sm" placeholder="Kowalski" @bind="Podrozni[index].Nazwisko">
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else if (CurrentStep == 2)
            {
                <div class="card shadow-sm border-0 p-4 animate-slide">
                    <h4 class="fw-bold mb-4">Dodatki do podróży</h4>
                    <div class="list-group">
                        <label class="list-group-item d-flex justify-content-between align-items-center p-3 cursor-pointer">
                            <div>
                                <input class="form-check-input me-3" type="checkbox" @onchange='(e) => ToggleAddon("Ubezpieczenie Premium", 150 * LiczbaOsob, (bool)e.Value!)'>
                                <strong>Ubezpieczenie Premium</strong>
                                <div class="small text-muted">Pełna ochrona kosztów leczenia dla wszystkich uczestników.</div>
                            </div>
                            <span class="badge bg-light text-dark border">+@(150 * LiczbaOsob) zł (całość)</span>
                        </label>
                        <label class="list-group-item d-flex justify-content-between align-items-center p-3 cursor-pointer">
                            <div>
                                <input class="form-check-input me-3" type="checkbox" @onchange='(e) => ToggleAddon("Prywatny transfer z lotniska", 80, (bool)e.Value!)'>
                                <strong>Prywatny transfer z lotniska</strong>
                                <div class="small text-muted">Dedykowany kierowca będzie czekał w hali przylotów.</div>
                            </div>
                            <span class="badge bg-light text-dark border">+80 zł</span>
                        </label>
                        <label class="list-group-item d-flex justify-content-between align-items-center p-3 cursor-pointer">
                            <div>
                                <input class="form-check-input me-3" type="checkbox" @onchange='(e) => ToggleAddon("Dodatkowy bagaż rejestrowany", 220, (bool)e.Value!)'>
                                <strong>Dodatkowy bagaż rejestrowany (20kg)</strong>
                                <div class="small text-muted">Dodatkowa duża walizka do luku bagażowego.</div>
                            </div>
                            <span class="badge bg-light text-dark border">+220 zł</span>
                        </label>
                    </div>
                </div>
            }
            else if (CurrentStep == 3)
            {
                <div class="card shadow-sm border-0 p-4 animate-slide">
                    <h4 class="fw-bold mb-4">Podsumowanie i płatność</h4>
                    <div class="alert alert-warning border-0 small">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        Sprawdź poprawność danych pasażerów przed dokonaniem płatności.
                    </div>
                    
                    <div class="mb-4 bg-light p-3 rounded border small">
                        <h6 class="fw-bold text-dark mb-2">Zweryfikuj uczestników wyjazdu:</h6>
                        @foreach (var p in Podrozni)
                        {
                            <div class="mb-1">👤 <strong>@p.Imie @p.Nazwisko</strong></div>
                        }
                    </div>

                    <div class="mb-4">
                        <h6 class="fw-bold">Metoda płatności</h6>
                        <div class="d-flex gap-3">
                            <div class="payment-card active p-3 border rounded text-center cursor-pointer">
                                <i class="bi bi-credit-card fs-3"></i>
                                <div class="small fw-bold">Karta / BLIK</div>
                            </div>
                            <div class="payment-card p-3 border rounded text-center cursor-pointer opacity-50">
                                <i class="bi bi-bank fs-3"></i>
                                <div class="small">Przelew bankowy</div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @* NAWIGACJA PRZYCISKAMI *@
            <div class="d-flex justify-content-between mt-4">
                <button class="btn btn-outline-secondary px-4 rounded-pill" @onclick="PrevStep" disabled="@(CurrentStep == 1)">Wstecz</button>
                @if (CurrentStep < 3)
                {
                    <button class="btn btn-primary px-5 rounded-pill shadow" @onclick="NextStep" disabled="@(CurrentStep == 1 && !WalidujDanePodroznych())">Dalej</button>
                }
                else
                {
                    <button class="btn btn-success px-5 rounded-pill shadow fw-bold" @onclick="FinalizePayment">POTWIERDZAM I PŁACĘ</button>
                }
            </div>
        </div>

        @* PRAWA KOLUMNA: PODSUMOWANIE KWOT POBRANYCH Z BAZY *@
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 sticky-top animate-slide" style="top: 100px;">
                <div class="card-body p-4">
                    @if (Offer != null && wybranyTermin != null)
                    {
                        <h5 class="fw-bold mb-1">@Offer.Hotel?.NazwaHotelu</h5>
                        <p class="text-muted small mb-3"><i class="bi bi-calendar-range me-1"></i> @wybranyTermin.DataOd.ToString("dd.MM.yyyy") - @wybranyTermin.DataDo.ToString("dd.MM.yyyy")</p>
                        <hr />
                        
                        <div class="d-flex justify-content-between small mb-2">
                            <span>Cena podstawowa (@LiczbaOsob os.)</span>
                            <span>@BasePrice zł</span>
                        </div>
                        @foreach (var addon in SelectedAddons)
                        {
                            <div class="d-flex justify-content-between small mb-2 text-success">
                                <span>+ @addon.Key</span>
                                <span>@addon.Value zł</span>
                            </div>
                        }
                        <hr>
                        <div class="d-flex justify-content-between align-items-center mb-0">
                            <span class="fw-bold fs-5">Do zapłaty:</span>
                            <span class="fw-bold fs-4 text-primary">@TotalPrice zł</span>
                        </div>
                        <div class="text-muted small text-end" style="font-size:0.7rem;">Zawiera VAT i opłaty lokalne</div>
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted small">Ładowanie podsumowania kosztów...</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int TerminCenaId { get; set; }
    [SupplyParameterFromQuery(Name = "offerId")] public int OfferId { get; set; }
    [SupplyParameterFromQuery(Name = "liczbaOsob")] public int LiczbaOsob { get; set; } = 2;

    private int CurrentStep = 1;
    private decimal BasePrice = 0;
    private Dictionary<string, decimal> SelectedAddons = new();
    private string? errorMessage;

    private ReadOfertaDto? Offer;
    private TerminCena? wybranyTermin;
    
    private List<CreateKlientDto> Podrozni = new();
    private CreateRezerwacjaDto rezerwacjaDto = new CreateRezerwacjaDto();

    private decimal TotalPrice => BasePrice + SelectedAddons.Sum(x => x.Value);

    protected override async Task OnInitializedAsync()
    {
        for (int i = 0; i < LiczbaOsob; i++)
        {
            Podrozni.Add(new CreateKlientDto());
        }

        try
        {
            var response = await Http.GetFromJsonAsync<ApiResponse<ReadOfertaDto>>($"api/oferty/{OfferId}");
            if (response != null && response.Sukces)
            {
                Offer = response.Dane;
                wybranyTermin = Offer?.TerminyCeny?.FirstOrDefault(t => t.Id == TerminCenaId);
                
                if (wybranyTermin != null)
                {
                    BasePrice = wybranyTermin.CenaPodstawowa * LiczbaOsob;
                }
                else
                {
                    errorMessage = "Nie odnaleziono wybranego terminu w bazie danych.";
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Problem z połączeniem z serwerem: {ex.Message}";
        }
    }

    private void NextStep() => CurrentStep++;
    private void PrevStep() => CurrentStep--;

    private void ToggleAddon(string name, decimal price, bool isSelected)
    {
        if (isSelected) SelectedAddons[name] = price;
        else SelectedAddons.Remove(name);
    }

    private bool WalidujDanePodroznych()
    {
        return Podrozni.All(p => !string.IsNullOrWhiteSpace(p.Imie) && !string.IsNullOrWhiteSpace(p.Nazwisko));
    }

    private async Task FinalizePayment()
    {
        errorMessage = null;
        var token = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "authToken");
        if (string.IsNullOrEmpty(token))
        {
            errorMessage = "Twoja sesja wygasła. Zaloguj się ponownie, aby dokonać rezerwacji!";
            return;
        }

        if (Offer == null || wybranyTermin == null)
        {
            errorMessage = "Błąd krytyczny: Brak załadowanych danych oferty.";
            return;
        }

        rezerwacjaDto.TerminCenaId = TerminCenaId;
        rezerwacjaDto.HotelId = Offer.HotelId;
        rezerwacjaDto.LiczbaOsob = LiczbaOsob;
        rezerwacjaDto.PracownikId = 0; 

        var response = await Http.PostAsJsonAsync("api/rezerwacje", rezerwacjaDto);
        if (response.IsSuccessStatusCode)
        {
            NavManager.NavigateTo("/my-bookings");
        }
        else
        {
            try
            {
                var bledy = await response.Content.ReadFromJsonAsync<List<string>>();
                errorMessage = bledy != null ? string.Join(", ", bledy) : "Serwer odrzucił żądanie rezerwacji.";
            }
            catch
            {
                errorMessage = await response.Content.ReadAsStringAsync();
            }
        }
    }
}

<style>
    /* Stepper Styles */
    .stepper-wrapper {
        margin-bottom: 2rem;
    }

    .stepper-line {
        position: absolute;
        top: 17px;
        left: 10%;
        right: 10%;
        height: 2px;
        background: #e0e0e0;
        z-index: 0;
    }

    .stepper-item {
        position: relative;
        z-index: 1;
        text-align: center;
        width: 100px;
    }

    .step-counter {
        width: 35px;
        height: 35px;
        background: #fff;
        border: 2px solid #e0e0e0;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 8px;
        font-weight: bold;
        color: #999;
        transition: 0.3s;
    }

    .stepper-item.active .step-counter {
        background: #003580;
        color: #fff;
        border-color: #003580;
    }

    .step-name {
        font-size: 0.75rem;
        font-weight: 500;
        color: #999;
    }

    .stepper-item.active .step-name {
        color: #003580;
        font-weight: bold;
    }

    /* Forms & Misc */
    .cursor-pointer {
        cursor: pointer;
    }

    .animate-slide {
        animation: slideIn 0.4s ease-out;
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .payment-card.active {
        border: 2px solid #003580 !important;
        background-color: #f0f4f8;
    }
</style>