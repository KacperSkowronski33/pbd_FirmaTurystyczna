@page "/login"
@using BookingApp.Shared.ApiResponse
@using BookingApp.Shared.DTOs.Auth
@inject HttpClient Http
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4">
            <div class="card shadow border-0 p-4">
                <h3 class="text-center mb-4 fw-bold">Logowanie</h3>

                @if (!string.IsNullOrEmpty(komunikat))
                {
                    <div class="alert alert-danger">@komunikat</div>
                }

                <div class="mb-3">
                    <label class="form-label">Email (Klient) lub Login (Pracownik)</label>
                    <input type="text" class="form-control" @bind="model.Identifier" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Hasło</label>
                    <input type="password" class="form-control" @bind="model.Haslo" />
                </div>

                <button class="btn btn-primary w-100 rounded-pill mt-2" @onclick="Zaloguj">Zaloguj się</button>
            </div>
        </div>
    </div>
</div>

@code {
    private LoginDto model = new() { Identifier = "", Haslo = "" };
    private string komunikat = "";

    private async Task Zaloguj()
    {
        komunikat = "";
        var response = await Http.PostAsJsonAsync("api/auth/login", model);

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<ApiResponse<LoginResultDto>>();
            
            if (result != null && result.Sukces && result.Dane != null)
            {
                await JSRuntime.InvokeVoidAsync("localStorage.setItem", "authToken", result.Dane.Token);
                NavManager.NavigateTo("/", forceLoad: true);
            }
            else
            {
                komunikat = result?.Wiadomosc ?? "Błąd logowania.";
            }
        }
        else
        {
            try
            {
                var result = await response.Content.ReadFromJsonAsync<ApiResponse<LoginResultDto>>();
                komunikat = result?.Wiadomosc ?? "Niepoprawny login lub hasło.";
            }
            catch
            {
                komunikat = "Niepoprawny login lub hasło.";
            }
        }
    }
}